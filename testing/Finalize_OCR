import re
import time
from ultralytics import YOLO
from collections import defaultdict, deque
import easyocr
import numpy as np
import cv2

start_time = time.time()

model = YOLO('../models/license_plate_best_new.pt')
reader = easyocr.Reader(['en'], gpu=True)

plate_pattern = re.compile(r'^[A-Z]{1,2}[0-9]{1,4}[A-Z]{1,3}$')

plate_history = defaultdict(lambda: deque(maxlen=15))
plate_final = {}

def get_box(x1, x2, y1, y2):
    return f"{int(x1//15)}_{int(x2//15)}_{int(y1//15)}_{int(y2//15)}"

def get_stable_plate(box_id, new_text):
    if new_text:
        plate_history[box_id].append(new_text)

        most_common = max(
            set(plate_history[box_id]),
            key=plate_history[box_id].count
        )
        plate_final[box_id] = most_common

    return plate_final.get(box_id, "")


def ocr_with_confidence(image):
    """
    return: list of (text, confidence)
    """
    try:
        result = reader.readtext(
            image,
            detail=1,
            paragraph=False,
            allowlist='ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789'
        )

        output = []
        for (bbox, text, conf) in result:
            text = re.sub(r'[^A-Z0-9]', '', text.upper())
            if text:
                output.append((text, conf))

        return output

    except Exception:
        return []



def preprocess_variants(plate_crop):
    gray = cv2.cvtColor(plate_crop, cv2.COLOR_BGR2GRAY)
    gray = cv2.bilateralFilter(gray, 9, 75, 75)

    clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8, 8))
    clahe_img = clahe.apply(gray)

    return [gray, clahe_img]


def recognize_plate(plate_crop):

    if plate_crop.size == 0:
        return ""

    variants = preprocess_variants(plate_crop)

    best_text = ""
    best_score = 0.0

    for variant in variants:


        plate_resized = cv2.resize(
            variant,
            None,
            fx=3,
            fy=3,
            interpolation=cv2.INTER_CUBIC
        )

        ocr_results = ocr_with_confidence(plate_resized)

        if not ocr_results:
            continue

  
        for text, conf in ocr_results:

            if len(text) < 4:
                continue

  
            regex_bonus = 1.0 if plate_pattern.match(text) else 0.6

            score = conf * regex_bonus

            if score > best_score:
                best_score = score
                best_text = text

    return best_text



input_foto = "input.jpg"
output_foto = "output.jpg"

img = cv2.imread(input_foto)

if img is None:
    raise ValueError("Input gambar tidak ditemukan")

height, width = img.shape[:2]

frame = img.copy()


CONF_THRESH = 0.25

results = model(frame, verbose=False)

for r in results:
    for box in r.boxes:

        conf = float(box.conf.item())
        if conf < CONF_THRESH:
            continue

        x1, y1, x2, y2 = map(int, box.xyxy.cpu().numpy()[0])

        x1 = max(0, x1)
        y1 = max(0, y1)
        x2 = min(width, x2)
        y2 = min(height, y2)

        pad = 8

        plate_crop = frame[
            max(0, y1 - pad):min(height, y2 + pad),
            max(0, x1 - pad):min(width, x2 + pad)
        ]

        text = recognize_plate(plate_crop)

        stable_id = get_box(x1, x2, y1, y2)
        final_text = get_stable_plate(stable_id, text)

        # DRAW BOX
        cv2.rectangle(frame, (x1, y1), (x2, y2), (0, 255, 0), 2)

        if final_text:

            (tw, th), _ = cv2.getTextSize(
                final_text,
                cv2.FONT_HERSHEY_SIMPLEX,
                1,
                2
            )

            cv2.rectangle(
                frame,
                (x1, y1 - th - 10),
                (x1 + tw, y1),
                (0, 0, 0),
                -1
            )

            cv2.putText(
                frame,
                final_text,
                (x1, y1 - 10),
                cv2.FONT_HERSHEY_SIMPLEX,
                1,
                (0, 255, 0),
                2
            )

            print("DETECTED:", final_text, "| CONF:", round(conf, 2))

# SAVE OUTPUT
cv2.imwrite(output_foto, frame)

# TIME
end_time = time.time()
print(f"\nPROCESS TIME: {end_time - start_time:.2f} sec")
print("Saved:", output_foto)